{
  "name": "pouchdb-adapter-react-native-sqlite-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "run-pouchdb-server": "npx -y pouchdb-server@5.0.1-rc1.0 -m -p 5984",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "react-native build-ios --scheme PouchdbAdapterReactNativeSqliteExample --mode Debug --extra-params \"-sdk iphonesimulator CC=clang CPLUSPLUS=clang++ LD=clang LDPLUSPLUS=clang++ GCC_OPTIMIZATION_LEVEL=0 GCC_PRECOMPILE_PREFIX_HEADER=YES ASSETCATALOG_COMPILER_OPTIMIZATION=time DEBUG_INFORMATION_FORMAT=dwarf COMPILER_INDEX_STORE_ENABLE=NO\""
  },
  "dependencies": {
    "@craftzdog/pouchdb-errors": "^9.0.1",
    "@op-engineering/op-sqlite": "^16.2.0",
    "debug": "^4.4.0",
    "events": "^3.3.0",
    "pouchdb-adapter-http": "^9.0.0",
    "pouchdb-core": "^9.0.0",
    "pouchdb-mapreduce": "^9.0.0",
    "pouchdb-replication": "^9.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-nitro-modules": "0.35.9",
    "react-native-quick-base64": "3.0.0",
    "react-native-quick-crypto": "1.1.5",
    "react-native-url-polyfill": "3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.7.6",
    "react-native-builder-bob": "^0.42.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-monorepo-config": "^0.3.5"
  },
  "op-sqlite": {
    "fts5": true
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
